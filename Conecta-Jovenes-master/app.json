{
  "expo": {
    "name": "Conecta",
    "slug": "ventanas-iniciar-sesion",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/LOGO HC Completo Colores.png",
    "scheme": "conecta",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.javisa.ventanasiniciarsesion",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.javisa.ventanasiniciarsesion",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/LOGO HC Completo Colores.png",
        "backgroundColor": "#E6F4FE"
      },
      "permissions": [
        "INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/LOGO HC Completo Colores.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "60e07072-8b14-44af-84bc-b2dcf2e0a769"
      }
    }
  }
}
